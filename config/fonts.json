  "usage": {
    "online": {
      "description": "HTML 中通过 Google Fonts CDN 加载（推荐，零配置）",
      "template": "<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family={FONT_NAME}&display=swap\" />"
    },
    "local": {
      "description": "通过 @font-face 加载本地字体（用于非 Google Fonts 字体或离线环境）",
      "template": "@font-face { font-family: '{FONT_NAME}'; src: url('./fonts/{FILE}') format('truetype'); }"
    }
  }
